# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Test scripts
test-*.js
test-*.mjs

node_modules
dist
dist-ssr
*.local
graphify-out

# Environment variables (contains API keys — never commit)
.env
.env.*
!.env.example

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Ignore all assets in public/assets except folders
public/assets/*
!public/assets/.gitkeep

# Ignore all assets in src/assets by default
src/assets/*

# Exceptions - Allow all media/image assets in src/assets
!src/assets/*.webp
!src/assets/*.png
!src/assets/*.svg
!src/assets/*.jpg
!src/assets/*.mp3
!src/assets/*.mp4
!src/assets/*.glb
!src/assets/*.jpeg
!src/assets/*.webm


